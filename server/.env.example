# MongoDB connection string
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/stdout?retryWrites=true&w=majority
# For local development: mongodb://127.0.0.1:27017/stdout
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/stdout?retryWrites=true&w=majority

# Server port
PORT=3001

# JWT secret for authentication (IMPORTANT: Change this in production!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# OpenAI API key
OPENAI_API_KEY=sk-your-api-key-here

# Frontend URL (for CORS in production)
# Example: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# Environment (development or production)
NODE_ENV=development
